# API Keys and Environment Variables
# Fill in your real values below — NEVER commit this file

# === Tavily ===
 # Tavily API key
TAVILY_API_KEY=""    

# === Supabase ===
# Supabase personal access token (MCP)
SUPABASE_API_PAT=""                       
# e.g. https://xyzabc.supabase.co
SUPABASE_PROJECT_URL=""                   
# anon/service role key from Supabase dashboard
SUPABASE_PROJECT_KEY=""                    

# === Gemini ===
# Google AI Studio API key
GEMINI_API_KEY=""                         

# === OpenRouter ===
# OpenRouter API key
OPENROUTER_API_KEY=                       
# OpenRouter model to use for answer generation (default: Claude Sonnet 4)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4    
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5  
#OPENROUTER_MODEL=anthropic/claude-opus-4
#OPENROUTER_MODEL=anthropic/claude-opus-4-5