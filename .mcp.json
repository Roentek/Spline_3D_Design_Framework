{
  "mcpServers": {
    "tavily-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp@latest"
      ],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}",
        "DEFAULT_PARAMETERS": "{\"include_images\": true, \"max_results\": 15, \"search_depth\": \"advanced\"}"
      }
    },
    "openrouter-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@physics91/openrouter-mcp",
        "start"
      ],
      "env": {
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}"
      }
    },
    "spline-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "spline-mcp-server"
      ]
    }
  }
}
