{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Spline 3D Start Server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "server:app",
        "--host", "127.0.0.1",
        "--port", "8080",
        "--reload"
      ],
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "postDebugTask": "open-browser"
    }
  ]
}
